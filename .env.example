GEMINI_API_KEY=your_key_here

# Optional runtime knobs
ROBOSS_RUNS_DIR=runs
ROBOSS_VIDEO_MODEL=gemini-omni-flash-preview
ROBOSS_LABEL_MODEL=gemini-3.5-flash
ROBOSS_GATE2_ENABLED=true
ROBOSS_LABEL_ON_ACCEPT=true
ROBOSS_ANNOTATE_ENABLED=false
ROBOSS_DETERMINISTIC_AGENTS=true
ROBOSS_START_FRAME_WORKERS=2

# Async pipeline concurrency caps
ROBOSS_VIDEO_WORKERS=8      # concurrent scenario chains in a batch
ROBOSS_GEN_WORKERS=4        # concurrent video generations (network-bound)
ROBOSS_VERIFY_WORKERS=2     # concurrent verifications (CPU-bound: YOLO)
ROBOSS_LABEL_WORKERS=4      # concurrent labeling jobs (network-bound)
TRACKING_CONCURRENCY=4      # parallel object-tracking calls inside one labeling job