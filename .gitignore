# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.venv/
build/
dist/

# Node / frontend
node_modules/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets
.env
.env.*
credentials*.json

# Stray generated media in repo root
/*.mp4
/*.png

# Common generated media and large local artifacts
*.avi
*.mov
*.mkv
*.webm
*.wav
*.mp3
*.parquet
*.npz
*.npy
*.onnx
*.safetensors
*.ckpt
*.pth
.ultralytics/

# roboss-film: keep the text/code/manifest scaffolding, exclude heavy media
# (669 PNG frames + 88 MP4 clips ≈ 667 MB — regenerable render artifacts)
roboss-film/clips/
roboss-film/roughcut/
roboss-film/selects/**
roboss-film/slates/
roboss-film/**/*.png
roboss-film/**/*.mp4
# ...but DO commit the five selects clips the bench fixture references (C01-C05).
!roboss-film/selects/
!roboss-film/selects/C01.mp4
!roboss-film/selects/C02.mp4
!roboss-film/selects/C03.mp4
!roboss-film/selects/C04.mp4
!roboss-film/selects/C05.mp4

# Model weights
*.pt
# ...but DO commit the specific runtime weights teammates need (all <100MB).
# CLIP ViT-B-32.pt (337MB) stays ignored: over GitHub's 100MB cap and unused
# by the bench/tests (see scripts/fetch_assets.py if ever needed).
!v2r/yolo11n.pt
!v2r/yolov8s-worldv2.pt
!v2r/assets/superanimal/*.pt
v2r/assets/models/*.task
v2r/assets/models/*.pt
!v2r/assets/models/.gitkeep
v2r/assets/body_models/*
!v2r/assets/body_models/README.md
v2r/assets/robots/*/meshes/
# Menagerie binary mesh assets (~100 MB, re-downloadable; see v2r/assets/robots/README.md)
v2r/assets/robots/*/assets/

# v2r/data is intentionally trackable so generated demo videos can be pushed.
# Workspaces: ignore heavy generated media (videos, depth PNGs, hdf5) but DO
# commit the tabular label/retarget artifacts (*.parquet, e.g. cmd_twist,
# qpos, keypoints). The **/ un-ignore lets git descend into the tree; the
# trailing negation overrides both this rule and the global *.parquet above.
v2r/workspaces/**
!v2r/workspaces/**/
!v2r/workspaces/**/*.parquet
!v2r/workspaces/**/utterances.json
v2r/.gpu_locks/
demo/.cache/
*_report.json
annotated*.mp4
scenario_bundle/

# Generated pipeline outputs (videos, reports, labels).S
/runs/*

# OS
.DS_Store
Thumbs.db

# runtime logs
backend.log
backend.err
